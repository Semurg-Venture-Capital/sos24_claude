generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Locale {
  uz_Latn
  uz_Cyrl
  ru
  en
}

enum DocumentKind {
  PASSPORT
  DRIVER_LICENSE
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ProductType {
  OSAGO
  KASKO
  HEALTH
  HOME
  FINANCE
  LIFE
  TRAVEL
  OTHER
}

// Как считается цена продукта:
//  COEFFICIENT — авто (ОСАГО/КАСКО): baseRate × коэффициенты (период/территория/стаж/лимит)
//  PLANS       — фикс-планы с ценой (здоровье/имущество/жизнь/путешествия/прочее)
enum PricingMode {
  COEFFICIENT
  PLANS
}

enum PolicyStatus {
  DRAFT
  PENDING_PAYMENT
  ACTIVE
  EXPIRED
  CANCELLED
}

enum DriverLimit {
  LIMITED
  UNLIMITED
}

enum CardBrand {
  UZCARD
  HUMO
  VISA
  MASTERCARD
}

enum PaymentMethod {
  WALLET
  CARD
  PAYME
  CLICK
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum WalletTxType {
  TOPUP
  PAYMENT
  REFUND
  BONUS
}

enum VerificationStatus {
  NOT_VERIFIED
  MYID_VERIFIED
}

enum UserRole {
  USER
  ADMIN
  ADJUSTER
  SUPPORT
  PARTNER // владелец B2B-кабинета (страховая компания ИЛИ сервис-партнёр), вход через partner.sos24.uz
}

enum PartnerType {
  STO
  CLINIC
  TOWING
}

enum PartnerBookingStatus {
  PENDING // создана, ждёт подтверждения партнёра
  CONFIRMED // подтверждена
  CANCELLED // отменена
  COMPLETED // выполнена (можно оставить отзыв)
}

enum IncidentType {
  ACCIDENT // ДТП
  DAMAGE // Повреждение
  THEFT // Угон
}

enum AdjusterStatus {
  NEW
  ACCEPTED
  EN_ROUTE
  COMPLETED
  CANCELLED
}

enum DevicePlatform {
  IOS
  ANDROID
}

// Тип уведомления — определяет иконку/цвет на клиенте и раздел для перехода.
enum NotificationType {
  POLICY_ACTIVATED
  POLICY_EXPIRING
  CLAIM_STATUS
  EUROPROTOCOL_STATUS
  SUPPORT_REPLY
  PARTNER_BOOKING
  PROMO
  SOS_ALERT
  SYSTEM
}

// ── Поддержка (чат) ──
// Тикетная модель: пользователь создаёт обращения, оператор отвечает.
enum SupportTicketStatus {
  OPEN // открыто, ждёт ответа оператора / в переписке
  PENDING // оператор ждёт ответа пользователя
  CLOSED // обращение закрыто
}

enum SupportCategory {
  POLICY // полисы
  PAYMENT // оплата
  ACCIDENT // ДТП / страховой случай
  ACCOUNT // аккаунт
  OTHER // другое
}

enum SupportSenderRole {
  USER
  SUPPORT
  SYSTEM
}

enum SupportMessageType {
  TEXT
  IMAGE
  FILE
  AUDIO
  SYSTEM
}

model User {
  id                 String             @id @default(cuid())
  phone              String             @unique
  name               String?
  surname            String?
  patronymic         String?
  birthDate          DateTime?          @db.Date
  locale             Locale             @default(ru)
  pinfl              String?            @unique
  verificationStatus VerificationStatus @default(NOT_VERIFIED)
  role               UserRole           @default(USER)

  // Колл-центр: персональный WebRTC-extension оператора (FreePBX) + секрет.
  // Заполняет админ при заведении оператора; бэкенд отдаёт их только этому оператору.
  sipExtension String? @map("sip_extension")
  sipSecret    String? @map("sip_secret")

  // Дополнительные поля из MyID (заполняются при верификации)
  nameEn      String? // first_name_en (латиница)
  surnameEn   String? // last_name_en (латиница)
  gender      String? // 'M' | 'F'
  birthPlace  String? // место рождения
  nationality String? // национальность (например 'UZB')
  citizenship String? // гражданство
  address     String? // постоянный адрес прописки
  myidRaw     Json? // полный сырой ответ MyID API (аудит + будущие поля)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicles         Vehicle[]
  documents        Document[]
  drivers          Driver[]
  policies         Policy[]
  cards            Card[]
  wallet           Wallet?
  payments         Payment[]
  adjusterRequests AdjusterRequest[] @relation("RequestOwner")
  assignedRequests AdjusterRequest[] @relation("AssignedAdjuster")
  euroProtocols    EuroProtocol[]
  notifications    Notification[]
  deviceTokens     DeviceToken[]
  supportTickets   SupportTicket[]   @relation("TicketOwner")
  assignedTickets  SupportTicket[]   @relation("TicketAgent")
  supportMessages  SupportMessage[]
  partnerReviews   PartnerReview[]
  partnerBookings  PartnerBooking[]
  medicalProfile   MedicalProfile?
  emergencyContacts EmergencyContact[]
  sosAlerts        SosAlert[]        @relation("SosOwner")
  dispatchedSos    SosAlert[]        @relation("SosDispatcher")
  triageSessions   TriageSession[]
  wearables        WearableConnection[]

  // B2B-кабинет (роль PARTNER): пользователь владеет РОВНО одной сущностью — компанией ИЛИ точкой.
  ownedCompany InsuranceCompany? @relation("CompanyOwner")
  ownedPartner Partner?          @relation("PartnerOwner")

  // Колл-центр: звонки клиента (как звонящего) и обработанные оператором.
  calls        Call[] @relation("CallCaller")
  handledCalls Call[] @relation("CallOperator")

  @@map("users")
}

model Document {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  kind       DocumentKind
  series     String
  number     String
  issuedAt   DateTime       @db.Date
  issuedBy   String?
  pinfl      String? // только для PASSPORT (14 цифр)
  expiresAt  DateTime?      @db.Date // только для DRIVER_LICENSE
  categories String? // только для DRIVER_LICENSE (CSV: "B,C")
  status     DocumentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, kind])
  @@map("documents")
}

model Vehicle {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plate  String
  brand  String
  model  String
  year   Int
  engine String? // "1.5 л"
  power  String? // "105 л.с."
  vin    String?
  color  String?

  // Фото авто, загруженное пользователем (ключ в MinIO). Приоритетнее рендера imagin.
  photoKey String?

  // --- Данные из НАПП (e-osgo.uz /provider/osago/vehicle). Промо-поля для админки/полисов. ---
  techPassportSeria  String? // серия техпаспорта (AAF)
  techPassportNumber String? // номер техпаспорта (2949568)
  techPassportDate   DateTime? // дата выдачи техпаспорта
  vehicleTypeId      Int? // тип ТС (ref vehicle-types-osago: 1=легковой и т.д.)
  bodyNumber         String? // номер кузова / VIN из НАПП
  engineNumber       String? // номер двигателя
  fuelType           String? // код типа топлива (отдельного справочника НАПП нет)
  seats              Int? // мест сидячих
  stands             Int? // мест стоячих
  fullWeight         String? // полная масса, кг
  emptyWeight        String? // снаряжённая масса, кг
  division           String? // отдел регистрации ТС
  pVehicleId         String? // id ТС в гос. реестре
  ownerName          String? // ФИО / название владельца
  ownerInn           String? // ИНН (если владелец — юрлицо)
  ownerPinfl         String? // ПИНФЛ (если владелец — физлицо)
  nappRaw            Json? // полный ответ НАПП по ТС (TechPassportInfo)
  nappOrgRaw         Json? // карточка организации-владельца (/provider/inn), если юрлицо
  nappSyncedAt       DateTime? // когда последний раз подтянули из НАПП

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  policies      Policy[]
  euroProtocols EuroProtocol[]

  @@unique([userId, plate])
  @@index([userId])
  @@map("vehicles")
}

// Водитель — отдельная сущность. Один пользователь может вписать в свой полис
// нескольких водителей (себя, жену, родственника по доверенности). Driver не
// обязательно равен User: можно записать чужого водителя по его ФИО + ВУ,
// без аккаунта в системе.
model Driver {
  id     String @id @default(cuid())
  userId String // владелец списка (тот кто оформляет полис)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name            String // полное ФИО
  licenseSeries   String?
  licenseNumber   String?
  experienceYears Int       @default(0)
  birthDate       DateTime? @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  policyDrivers PolicyDriver[]

  @@index([userId])
  @@map("drivers")
}

model Policy {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type   ProductType
  status PolicyStatus @default(DRAFT)

  // Страховая компания / продукт / тарифный план (nullable — обратная совместимость
  // со старыми полисами, оформленными до появления каталога компаний).
  companyId String?
  company   InsuranceCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  productId String?
  product   InsuranceProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  planId    String?
  plan      ProductPlan?      @relation(fields: [planId], references: [id], onDelete: SetNull)

  // Авто — только для OSAGO/KASKO
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  // Период действия
  startDate    DateTime @db.Date
  endDate      DateTime @db.Date
  periodMonths Int // 3, 6, 12 (для ОСАГО/КАСКО) или 12 для остальных

  // Ограничения водителей (только OSAGO)
  driverLimit DriverLimit @default(LIMITED)

  // Цена
  basePrice  Int // в сумах
  discount   Int     @default(0)
  totalPrice Int // basePrice - discount
  promoCode  String?

  // Структура коэффициентов / расчёта — JSON для гибкости.
  // Для ОСАГО: { periodK, territoryK, experienceK, limitK }, для health/home — null.
  coefficients Json?

  // Заполняется при ACTIVE
  policyNumber String? @unique
  qrPayload    String? // URL публичной проверки (в QR)
  publicToken  String? @unique @map("public_token") // токен для /v/<token>

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  activatedAt DateTime?

  drivers PolicyDriver[]

  @@index([userId, status])
  @@index([companyId])
  @@index([productId])
  @@map("policies")
}

// Страховая компания (страховщик). SOS24 — платформа-агрегатор, а не страховщик;
// полисы выдают эти компании. Управляется из админки.
model InsuranceCompany {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  logoKey     String? // ключ файла-логотипа в MinIO
  description String?
  active      Boolean @default(true)
  sortOrder   Int     @default(0)

  // Владелец B2B-кабинета (роль PARTNER). 1:1 — у компании максимум один логин-владелец.
  ownerId String? @unique @map("owner_id")
  owner   User?   @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  products InsuranceProduct[]
  policies Policy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("insurance_companies")
}

// Страховой продукт конкретной компании (ОСАГО, КАСКО, здоровье, имущество и т.д.).
// Контент карточки (covers/exceptions/steps/faqs) хранится в content (Json), редактируется в админке.
model InsuranceProduct {
  id        String           @id @default(cuid())
  companyId String
  company   InsuranceCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  type             ProductType
  name             String
  slug             String
  shortDescription String?
  longDescription  String?

  pricingMode PricingMode @default(PLANS)
  baseRate    Int? // для COEFFICIENT (ОСАГО/КАСКО) — базовая ставка в сумах

  // { covers:[{title,body}], exceptions:[string], steps:[{title,body}], faqs:[{question,answer}] }
  content Json?

  active    Boolean @default(true)
  sortOrder Int     @default(0)

  plans    ProductPlan[]
  policies Policy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, slug])
  @@index([companyId, active])
  @@map("insurance_products")
}

// Тарифный план продукта (Базовый / Стандарт / Премиум) с фикс-ценой и покрытием.
// Используется при pricingMode = PLANS.
model ProductPlan {
  id        String           @id @default(cuid())
  productId String
  product   InsuranceProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  name           String
  price          Int // цена в сумах
  coverageAmount Int? // страховая сумма (покрытие), сум
  features       Json? // string[] — что входит

  active    Boolean @default(true)
  sortOrder Int     @default(0)

  policies Policy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, active])
  @@map("product_plans")
}

// M:N связь полиса и водителей.
model PolicyDriver {
  policyId String
  policy   Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  driverId String
  driver   Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@id([policyId, driverId])
  @@map("policy_drivers")
}

model Promo {
  id          String    @id @default(cuid())
  code        String    @unique
  discountPct Int // 0..100
  validFrom   DateTime?
  validUntil  DateTime?
  maxUses     Int? // null = безлимит
  usesCount   Int       @default(0)
  isActive    Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("promos")
}

model Card {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  brand     CardBrand
  last4     String // 4 цифры
  expiry    String // "MM/YY"
  token     String // mock-токен от платёжки (в реале — Uzcard tokenization)
  isDefault Boolean   @default(false)
  balance   Int       @default(5000000) // mock-баланс карты в сумах

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[]

  @@unique([userId, token])
  @@index([userId])
  @@map("cards")
}

model Wallet {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  balance Int @default(0) // в сумах

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id       String @id @default(cuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  type        WalletTxType
  amount      Int // положительное для TOPUP/REFUND/BONUS, отрицательное для PAYMENT
  description String?
  paymentId   String? // связь с Payment если это списание за полис

  createdAt DateTime @default(now())

  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

// Категория партнёров (управляется в админке): СТО, клиника, эвакуатор, автомойка…
model PartnerCategory {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  icon      String? // имя иконки/emoji для чипа
  color     String?
  sortOrder Int       @default(0)
  active    Boolean   @default(true)
  partners  Partner[]
  createdAt DateTime  @default(now())

  @@map("partner_categories")
}

model Partner {
  id      String       @id @default(cuid())
  name    String
  type    PartnerType? // legacy; основная категоризация — categoryId
  address String
  phone   String?
  rating  Float        @default(0)
  isOpen  Boolean      @default(true) // ручной override; фактическое «открыто» считается из workingHours
  city    String       @default("Ташкент")
  lat     Float?
  lng     Float?

  categoryId  String?
  category    PartnerCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  description String?          @db.Text
  logoKey     String? // лого в MinIO
  coverKey    String? // баннер в MinIO
  email       String?
  website     String?
  workingHours Json? // { mon: {open:"09:00", close:"18:00"} | null, ... }
  reviewCount Int     @default(0)
  active      Boolean @default(true)
  sortOrder   Int     @default(0)

  // Владелец B2B-кабинета (роль PARTNER). 1:1 — у точки максимум один логин-владелец.
  ownerId String? @unique @map("owner_id")
  owner   User?   @relation("PartnerOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  services PartnerService[]
  reviews  PartnerReview[]
  bookings PartnerBooking[]
  doctors  Doctor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([city])
  @@index([categoryId])
  @@map("partners")
}

// Сессия ИИ-триажа (M14.2/14.3). Чат + вердикт. Чувствительные поля
// (messages/symptoms/verdict) ЗАШИФРОВАНЫ (AES-256-GCM). urgency: low|medium|high.
model TriageSession {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages   String?  @db.Text // ШИФРУЕТСЯ — JSON [{role,text,at}]
  symptoms   String?  @db.Text // ШИФРУЕТСЯ — JSON string[]
  verdict    String?  @db.Text // ШИФРУЕТСЯ — предв. диагноз (текст)
  urgency    String? // low | medium | high
  confidence Int? // 0..100
  step       Int      @default(0) // сколько уточняющих вопросов задано
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, createdAt])
  @@map("triage_sessions")
}

// Экстренные контакты (M14.11): кого оповестить при SOS. Лимит 3 (в сервисе).
model EmergencyContact {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  relation  String? // «супруга», «брат» …
  phone     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("emergency_contacts")
}

enum SosStatus {
  ACTIVE
  CANCELLED
  RESOLVED
}

// Тревога ЧП/SOS (M14.12): факт срабатывания + геолокация + оповещения + диспетчер.
model SosAlert {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("SosOwner", fields: [userId], references: [id], onDelete: Cascade)
  lat         Float?
  lng         Float?
  address     String?
  status      SosStatus @default(ACTIVE)
  notified    Int       @default(0) // сколько экстренных контактов успешно оповещено

  // Диспетчер, принявший тревогу (роль ADMIN/SUPPORT).
  dispatcherId   String?
  dispatcher     User?     @relation("SosDispatcher", fields: [dispatcherId], references: [id], onDelete: SetNull)
  acknowledgedAt DateTime?
  note           String?

  notifications SosNotification[]

  createdAt   DateTime  @default(now())
  cancelledAt DateTime?

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("sos_alerts")
}

enum SosNotifyStatus {
  PENDING
  SENT
  FAILED
}

// Оповещение конкретного экстренного контакта при SOS (SMS). Статус доставки.
model SosNotification {
  id          String          @id @default(cuid())
  alertId     String
  alert       SosAlert        @relation(fields: [alertId], references: [id], onDelete: Cascade)
  contactName String
  phone       String
  channel     String          @default("SMS")
  status      SosNotifyStatus @default(PENDING)
  error       String?
  sentAt      DateTime?
  createdAt   DateTime        @default(now())

  @@index([alertId])
  @@map("sos_notifications")
}

// Мед.карта (Medical ID · M14.9/14.10). Чувствительные поля (allergies/chronic/
// medications) хранятся ЗАШИФРОВАННЫМИ (AES-256-GCM, common/crypto/field-cipher).
model MedicalProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName    String?
  birthDate   String? // «15.03.1994» (свободный формат из формы)
  gender      String? // 'M' | 'F'
  bloodType   String? // «B(III) Rh+»
  heightCm    Int?
  weightKg    Int?
  allergies   String? @db.Text // ШИФРУЕТСЯ (JSON-массив строк)
  chronic     String? @db.Text // ШИФРУЕТСЯ
  medications String? @db.Text // ШИФРУЕТСЯ
  organDonor  Boolean?
  pregnancy   Boolean?
  dmsPolicy   String?
  doctorName  String?
  consentAt   DateTime? // согласие на обработку мед-данных (фиксируется при первом сохранении)
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  @@map("medical_profiles")
}

// ── Носимые трекеры здоровья (M14 · WHOOP и т.п.) ──
enum WearableProvider {
  WHOOP
}

enum WearableStatus {
  CONNECTED
  DISCONNECTED
  ERROR
}

// Подключение носимого устройства пользователя. Токены — ШИФРУЮТСЯ (field-cipher, как мед-поля).
// Один провайдер на пользователя (unique [userId, provider]).
model WearableConnection {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       WearableProvider
  status         WearableStatus   @default(CONNECTED)
  providerUserId String? // id пользователя на стороне провайдера (whoop user_id)
  accessToken    String?          @db.Text // ШИФРУЕТСЯ
  refreshToken   String?          @db.Text // ШИФРУЕТСЯ
  scope          String?
  expiresAt      DateTime? // истечение access-token
  lastSyncAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  snapshot WhoopSnapshot?

  @@unique([userId, provider])
  @@index([userId])
  @@map("wearable_connections")
}

// Последние метрики WHOOP на пользователя (для быстрой отдачи в приложение). 1:1 с подключением.
model WhoopSnapshot {
  id           String             @id @default(cuid())
  connectionId String             @unique
  connection   WearableConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  userId       String             @unique

  // Готовность (Recovery)
  recoveryScore Int? // 0..100
  hrvMs         Float? // ВСР (rmssd, мс)
  restingHr     Int? // пульс покоя
  spo2          Float? // сатурация, % (только 4.0+)
  skinTempC     Float? // температура кожи (только 4.0+)
  recoveryAt    DateTime?

  // Сон (Sleep)
  sleepPerformance  Int? // %
  sleepTotalMinutes Int?
  sleepLightMin     Int?
  sleepDeepMin      Int?
  sleepRemMin       Int?
  sleepAwakeMin     Int?
  respiratoryRate   Float?
  sleepAt           DateTime?

  // Сутки / нагрузка (Cycle)
  dayStrain Float? // 0..21
  avgHr     Int?
  maxHr     Int?
  cycleAt   DateTime?

  updatedAt DateTime @updatedAt

  @@map("whoop_snapshots")
}

// Лог каждого вызова к LLM (Gemini): фича, модель, токены, время, результат.
// userId — необязателен (nullable, без FK) — логируем и системные вызовы.
model AiUsageLog {
  id           String   @id @default(cuid())
  userId       String?
  feature      String // triage_ask | triage_finalize | euro_voice ...
  model        String
  promptTokens Int      @default(0)
  outputTokens Int      @default(0)
  totalTokens  Int      @default(0)
  latencyMs    Int      @default(0)
  ok           Boolean  @default(true)
  error        String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([feature])
  @@map("ai_usage_logs")
}

// Врач при клинике-партнёре (M14 · раздел «Здоровье»). Запись к врачу —
// поверх PartnerBooking (см. поле doctorId ниже), максимум переиспользования.
model Doctor {
  id           String  @id @default(cuid())
  partnerId    String? // клиника (Partner); null — частный врач
  partner      Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  fullName     String
  specialty    String // Терапевт / ЛОР / Кардиолог …
  experienceY  Int? // стаж, лет
  bio          String?  @db.Text
  photoKey     String? // фото в MinIO
  rating       Float    @default(0)
  reviewCount  Int      @default(0)
  pricePrimary Int? // первичный приём, сум
  priceRepeat  Int? // повторный приём
  priceVideo   Int? // видео (для будущего)
  videoEnabled Boolean  @default(false) // видео-приём (пока false везде)
  verified     Boolean  @default(false) // бейдж «Партнёр SOS24»
  active       Boolean  @default(true)
  workingHours Json? // { mon: {open,close} | null, ... } — для расчёта слотов; fallback — часы клиники

  bookings  PartnerBooking[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([partnerId])
  @@index([specialty])
  @@map("doctors")
}

// Услуга партнёра с ценой (цена опциональна).
model PartnerService {
  id          String  @id @default(cuid())
  partnerId   String
  partner     Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  name        String
  description String?
  priceFrom   Int? // сум
  priceTo     Int?
  durationMin Int? // длительность для расчёта слотов
  active      Boolean @default(true)
  sortOrder   Int     @default(0)

  bookings  PartnerBooking[] @relation("BookingServices")
  createdAt DateTime         @default(now())

  @@index([partnerId])
  @@map("partner_services")
}

// Отзыв (создаётся только после завершённой записи).
model PartnerReview {
  id        String  @id @default(cuid())
  partnerId String
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookingId String?         @unique
  booking   PartnerBooking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  rating    Int // 1..5
  text      String?  @db.Text
  createdAt DateTime @default(now())

  @@index([partnerId, createdAt])
  @@map("partner_reviews")
}

// Запись на услугу.
model PartnerBooking {
  id        String  @id @default(cuid())
  partnerId String
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  services    PartnerService[]     @relation("BookingServices")
  policyId    String? // опциональная привязка к полису
  scheduledAt DateTime
  status      PartnerBookingStatus @default(PENDING)
  comment     String?

  // Запись к врачу (M14): если задан — это приём к конкретному доктору клиники.
  doctorId String?
  doctor   Doctor? @relation(fields: [doctorId], references: [id], onDelete: SetNull)

  review    PartnerReview?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([partnerId, scheduledAt])
  @@index([userId, createdAt])
  @@index([doctorId, scheduledAt])
  @@map("partner_bookings")
}

model Payment {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  policyId String
  // Не делаем relation на Policy здесь чтобы избежать циклов в seed/удалении;
  // policyId хранится как FK-like reference.

  amount Int
  method PaymentMethod
  cardId String?
  card   Card?         @relation(fields: [cardId], references: [id], onDelete: SetNull)

  status PaymentStatus @default(PENDING)
  error  String? // текст ошибки если FAILED

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  paidAt    DateTime?

  @@index([userId, status])
  @@index([policyId])
  @@map("payments")
}

model AdjusterRequest {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("RequestOwner", fields: [userId], references: [id], onDelete: Cascade)

  policyId     String? // связанный полис (необязательно)
  incidentType IncidentType
  address      String
  lat          Float?
  lng          Float?
  comment      String?
  adjusterNote String?        @map("adjuster_note")
  status       AdjusterStatus @default(NEW)

  // Назначенный аджастер — системный пользователь с ролью ADJUSTER
  assignedAdjusterId String? @map("assigned_adjuster_id")
  assignedAdjuster   User?   @relation("AssignedAdjuster", fields: [assignedAdjusterId], references: [id], onDelete: SetNull)

  // Одноразовый аджастер (без аккаунта в системе)
  adjusterName  String? @map("adjuster_name")
  adjusterPhone String? @map("adjuster_phone")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status, createdAt])
  @@index([assignedAdjusterId])
  @@map("adjuster_requests")
}

// Второй участник европротокола — личность, подтверждённая через MyID.
// Find-or-create по ПИНФЛ. Не логинимый аккаунт (отдельно от User).
// Авто и полис участника привязаны к конкретному ДТП, а не к личности,
// поэтому здесь хранится только MyID-профиль.
model EuroParticipant {
  id    String @id @default(cuid())
  pinfl String @unique

  // MyID-профиль
  name        String?
  surname     String?
  patronymic  String?
  nameEn      String?   @map("name_en")
  surnameEn   String?   @map("surname_en")
  birthDate   DateTime? @map("birth_date")
  birthPlace  String?   @map("birth_place")
  gender      String?
  nationality String?
  citizenship String?
  address     String?

  // Паспорт
  passportSeria  String? @map("passport_seria")
  passportNumber String? @map("passport_number")

  myidRaw    Json?    @map("myid_raw")
  verifiedAt DateTime @default(now()) @map("verified_at")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  protocols EuroProtocol[]

  @@map("euro_participants")
}

// Статус европротокола (флоу урегулирования/выплаты).
enum EuroStatus {
  SUBMITTED // подано
  REVIEW // на рассмотрении
  NEED_INFO // требуется информация
  APPROVED // одобрено
  REJECTED // отклонено
  PAID // выплачено
}

// Оформленный европротокол — собранные данные ДТП (без PDF пока).
model EuroProtocol {
  id     String @id @default(cuid())
  number String @unique // EP-26-XXXXX

  // Сторона A — инициатор
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleId    String?
  vehicle      Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  selfVerified Boolean  @default(false)

  // Обстоятельства
  incidentDate DateTime
  incidentTime String
  place        String
  lat          Float?
  lng          Float?

  // Сторона B — второй участник
  participantId     String?          @map("participant_id")
  participant       EuroParticipant? @relation(fields: [participantId], references: [id], onDelete: SetNull)
  otherGov          String?          @map("other_gov")
  otherPhone        String?          @map("other_phone")
  otherVehicleRaw   Json?            @map("other_vehicle_raw") // TechPassportInfo из НАПП
  otherPolicySeria  String?          @map("other_policy_seria")
  otherPolicyNumber String?          @map("other_policy_number")
  otherPolicyValid  Boolean?         @map("other_policy_valid")

  // Схема / описание / фото
  schemeType     String? @map("scheme_type")
  schemeImageKey String? @map("scheme_image_key") // ключ нарисованной/загруженной схемы в MinIO
  description    String? // = оборот «1. ЙТҲ ҳолати» (обстоятельства своими словами)
  photos         Json? // массив ключей MinIO + метаданные

  // --- Общая часть бланка (пп. 4–6) ---
  medCheck           Boolean? @map("med_check") // 4. медосвидетельствование пройдено
  witnesses          String? // 5. свидетели (ФИО, адрес)
  officialRegistered Boolean? @map("official_registered") // 6. оформлено сотрудником ИИО/ДЙҲХ
  officerBadgeNo     String?  @map("officer_badge_no") // 6. № нагрудного знака

  // --- Обстоятельства ДТП: 22 чекбокса на каждую сторону (массив boolean[22]) ---
  circumstancesA Json? @map("circumstances_a")
  circumstancesB Json? @map("circumstances_b")

  // --- Сторона A: доп. поля бланка ---
  ownershipDocA String? @map("ownership_doc_a") // документ о праве владения (если водитель ≠ владелец)
  damageDescA   String? @map("damage_desc_a") // 12. описание повреждений
  objectionsA   String? @map("objections_a") // 13. возражения
  impactZoneA   String? @map("impact_zone_a") // 11. зона первого удара (код зоны)

  // --- Сторона B: ручной ввод (НАПП/MyID не покрывают) ---
  otherOwnerAddr        String?   @map("other_owner_addr")
  otherDlSeria          String?   @map("other_dl_seria")
  otherDlNumber         String?   @map("other_dl_number")
  otherDlCategories     String?   @map("other_dl_categories")
  otherDlIssue          DateTime? @map("other_dl_issue") @db.Date
  otherOwnershipDoc     String?   @map("other_ownership_doc")
  otherInsurer          String?   @map("other_insurer")
  otherPolicyValidUntil DateTime? @map("other_policy_valid_until") @db.Date
  damageDescB           String?   @map("damage_desc_b")
  objectionsB           String?   @map("objections_b")
  impactZoneB           String?   @map("impact_zone_b")

  // --- Оборот (стр. 2) ---
  driverRole      String?  @map("driver_role") // 'owner' | 'other'
  canMove         Boolean? @map("can_move") // ТС может двигаться самостоятельно
  cannotMovePlace String?  @map("cannot_move_place") // место стоянки, если не может
  remarks         String? // 4. Изоҳ (доп. замечания) — итоговый (нормализованный) текст
  remarksAudioKey String? // голосовая запись «Изоҳ» в MinIO (первоисточник)
  remarksRaw      String? @db.Text // сырой транскрипт голоса (до нормализации)

  // --- Подписи (OTP/MyID — храним факт + время, рендерим штамп) ---
  signedAAt DateTime? @map("signed_a_at") // сторона A (инициатор, MyID step-up)
  signedBAt DateTime? @map("signed_b_at") // сторона B (OTP по otherPhone)

  status    EuroStatus @default(SUBMITTED)
  adminNote String?    @map("admin_note")

  // Публичный неугадываемый токен для QR-проверки подлинности (api.sos24.uz/p/<token>)
  publicToken String? @unique @map("public_token")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status, createdAt])
  @@map("euro_protocols")
}

// Уведомление пользователя (in-app история + источник push).
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      NotificationType @default(SYSTEM)
  title     String
  body      String
  // Полезная нагрузка для перехода: { screen, params } (deep link в приложении).
  data      Json?

  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@map("notifications")
}

// Push-токен устройства (нативный: APNs для iOS, FCM для Android).
model DeviceToken {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  token      String         @unique
  platform   DevicePlatform
  lastSeenAt DateTime       @default(now())
  createdAt  DateTime       @default(now())

  @@index([userId])
  @@map("device_tokens")
}

// Обращение в поддержку (тикет). На пользователя может быть несколько.
model SupportTicket {
  id      String          @id @default(cuid())
  userId  String
  user    User            @relation("TicketOwner", fields: [userId], references: [id], onDelete: Cascade)

  subject  String
  category SupportCategory     @default(OTHER)
  status   SupportTicketStatus @default(OPEN)

  // Назначенный оператор (SUPPORT/ADMIN). Назначается при первом ответе / claim.
  agentId String?
  agent   User?   @relation("TicketAgent", fields: [agentId], references: [id], onDelete: SetNull)

  // Денормализация для быстрого списка без N+1.
  lastMessageAt      DateTime @default(now())
  lastMessagePreview String?
  unreadForUser      Int      @default(0)
  unreadForAgent     Int      @default(0)

  messages  SupportMessage[]
  calls     Call[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?

  @@index([userId, lastMessageAt])
  @@index([status, lastMessageAt])
  @@index([agentId, lastMessageAt])
  @@map("support_tickets")
}

// ──────────────────────────── Колл-центр (Asterisk/ARI) ────────────────────────────

enum CallDirection {
  INBOUND_EXTERNAL // звонок на наш внешний номер (PSTN/транк)
  INBOUND_APP      // звонок из мобильного приложения (WebRTC), известен userId
  OUTBOUND         // исходящий от оператора
}

enum CallStatus {
  RINGING   // поступил/в очереди/звонит у оператора
  ANSWERED  // оператор ответил
  MISSED    // не приняли (никто не ответил / абонент бросил в очереди)
  COMPLETED // завершён нормально
  FAILED    // техническая ошибка
}

// Журнал звонков колл-центра. Создаётся/обновляется ARI-приложением по событиям Asterisk.
model Call {
  id        String        @id @default(cuid())
  direction CallDirection
  status    CallStatus    @default(RINGING)

  // Asterisk-корреляция (для связи с CDR/записью и идемпотентности по событиям).
  channelId String? @unique @map("channel_id") // ARI channel.id
  linkedId  String? @map("linked_id") // Linkedid/uniqueid группы каналов
  queue     String?

  // Кто звонит / кого определили.
  externalNumber String? @map("external_number") // CallerID для внешних
  userId         String? @map("user_id") // определённый клиент (по номеру или in-app)
  user           User?   @relation("CallCaller", fields: [userId], references: [id], onDelete: SetNull)

  // Оператор, принявший звонок.
  operatorId String? @map("operator_id")
  operator   User?   @relation("CallOperator", fields: [operatorId], references: [id], onDelete: SetNull)

  // Тайминги.
  startedAt   DateTime  @default(now()) @map("started_at")
  answeredAt  DateTime? @map("answered_at")
  endedAt     DateTime? @map("ended_at")
  durationSec Int?      @map("duration_sec") // длительность разговора (answered→ended)
  waitSec     Int?      @map("wait_sec") // ожидание до ответа

  // Запись разговора (MixMonitor → MinIO).
  recordingKey String? @map("recording_key")

  // Привязка к заявке (омниканальность с Поддержкой) + заметка оператора.
  ticketId String?        @map("ticket_id")
  ticket   SupportTicket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  note     String?        @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, startedAt])
  @@index([operatorId, startedAt])
  @@index([userId, startedAt])
  @@index([direction, startedAt])
  @@map("calls")
}

// Сообщение в тикете.
model SupportMessage {
  id       String        @id @default(cuid())
  ticketId String
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  // Автор: для SYSTEM-сообщений senderId = null.
  senderId   String?
  sender     User?             @relation(fields: [senderId], references: [id], onDelete: SetNull)
  senderRole SupportSenderRole

  type SupportMessageType @default(TEXT)
  body String?            @db.Text

  // Вложение (presigned-загрузка в MinIO).
  attachmentKey  String?
  attachmentName String?
  attachmentMime String?
  attachmentSize Int?
  audioDuration  Int? // секунды, для AUDIO

  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([ticketId, createdAt])
  @@map("support_messages")
}
