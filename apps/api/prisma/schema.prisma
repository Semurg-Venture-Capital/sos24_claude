generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Locale {
  uz_Latn
  uz_Cyrl
  ru
  en
}

enum DocumentKind {
  PASSPORT
  DRIVER_LICENSE
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ProductType {
  OSAGO
  KASKO
  HEALTH
  HOME
  FINANCE
}

enum PolicyStatus {
  DRAFT
  PENDING_PAYMENT
  ACTIVE
  EXPIRED
  CANCELLED
}

enum DriverLimit {
  LIMITED
  UNLIMITED
}

enum CardBrand {
  UZCARD
  HUMO
  VISA
  MASTERCARD
}

enum PaymentMethod {
  WALLET
  CARD
  PAYME
  CLICK
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum WalletTxType {
  TOPUP
  PAYMENT
  REFUND
  BONUS
}

enum VerificationStatus {
  NOT_VERIFIED
  MYID_VERIFIED
}

enum UserRole {
  USER
  ADMIN
  ADJUSTER
}

enum PartnerType {
  STO
  CLINIC
  TOWING
}

enum IncidentType {
  ACCIDENT  // ДТП
  DAMAGE    // Повреждение
  THEFT     // Угон
}

enum AdjusterStatus {
  NEW
  ACCEPTED
  EN_ROUTE
  COMPLETED
  CANCELLED
}

model User {
  id                 String             @id @default(cuid())
  phone              String             @unique
  name               String?
  surname            String?
  patronymic         String?
  birthDate          DateTime?          @db.Date
  locale             Locale             @default(ru)
  pinfl              String?            @unique
  verificationStatus VerificationStatus @default(NOT_VERIFIED)
  role               UserRole           @default(USER)

  // Дополнительные поля из MyID (заполняются при верификации)
  nameEn      String?   // first_name_en (латиница)
  surnameEn   String?   // last_name_en (латиница)
  gender      String?   // 'M' | 'F'
  birthPlace  String?   // место рождения
  nationality String?   // национальность (например 'UZB')
  citizenship String?   // гражданство
  address     String?   // постоянный адрес прописки
  myidRaw     Json?     // полный сырой ответ MyID API (аудит + будущие поля)

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  vehicles          Vehicle[]
  documents         Document[]
  drivers           Driver[]
  policies          Policy[]
  cards             Card[]
  wallet            Wallet?
  payments          Payment[]
  adjusterRequests  AdjusterRequest[]  @relation("RequestOwner")
  assignedRequests  AdjusterRequest[]  @relation("AssignedAdjuster")
  euroProtocols     EuroProtocol[]

  @@map("users")
}

model Document {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  kind       DocumentKind
  series     String
  number     String
  issuedAt   DateTime       @db.Date
  issuedBy   String?
  pinfl      String?        // только для PASSPORT (14 цифр)
  expiresAt  DateTime?      @db.Date  // только для DRIVER_LICENSE
  categories String?        // только для DRIVER_LICENSE (CSV: "B,C")
  status     DocumentStatus @default(PENDING)

  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([userId, kind])
  @@map("documents")
}

model Vehicle {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  plate     String
  brand     String
  model     String
  year      Int
  engine    String?  // "1.5 л"
  power     String?  // "105 л.с."
  vin       String?
  color     String?

  // --- Данные из НАПП (e-osgo.uz /provider/osago/vehicle). Промо-поля для админки/полисов. ---
  techPassportSeria   String?   // серия техпаспорта (AAF)
  techPassportNumber  String?   // номер техпаспорта (2949568)
  techPassportDate    DateTime? // дата выдачи техпаспорта
  vehicleTypeId       Int?      // тип ТС (ref vehicle-types-osago: 1=легковой и т.д.)
  bodyNumber          String?   // номер кузова / VIN из НАПП
  engineNumber        String?   // номер двигателя
  fuelType            String?   // код типа топлива (отдельного справочника НАПП нет)
  seats               Int?      // мест сидячих
  stands              Int?      // мест стоячих
  fullWeight          String?   // полная масса, кг
  emptyWeight         String?   // снаряжённая масса, кг
  division            String?   // отдел регистрации ТС
  pVehicleId          String?   // id ТС в гос. реестре
  ownerName           String?   // ФИО / название владельца
  ownerInn            String?   // ИНН (если владелец — юрлицо)
  ownerPinfl          String?   // ПИНФЛ (если владелец — физлицо)
  nappRaw             Json?     // полный ответ НАПП по ТС (TechPassportInfo)
  nappOrgRaw          Json?     // карточка организации-владельца (/provider/inn), если юрлицо
  nappSyncedAt        DateTime? // когда последний раз подтянули из НАПП

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  policies  Policy[]
  euroProtocols EuroProtocol[]

  @@unique([userId, plate])
  @@index([userId])
  @@map("vehicles")
}

// Водитель — отдельная сущность. Один пользователь может вписать в свой полис
// нескольких водителей (себя, жену, родственника по доверенности). Driver не
// обязательно равен User: можно записать чужого водителя по его ФИО + ВУ,
// без аккаунта в системе.
model Driver {
  id          String   @id @default(cuid())
  userId      String   // владелец списка (тот кто оформляет полис)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String   // полное ФИО
  licenseSeries String?
  licenseNumber String?
  experienceYears Int   @default(0)
  birthDate   DateTime? @db.Date

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  policyDrivers PolicyDriver[]

  @@index([userId])
  @@map("drivers")
}

model Policy {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  type          ProductType
  status        PolicyStatus @default(DRAFT)

  // Авто — только для OSAGO/KASKO
  vehicleId     String?
  vehicle       Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  // Период действия
  startDate     DateTime     @db.Date
  endDate       DateTime     @db.Date
  periodMonths  Int          // 3, 6, 12 (для ОСАГО/КАСКО) или 12 для остальных

  // Ограничения водителей (только OSAGO)
  driverLimit   DriverLimit  @default(LIMITED)

  // Цена
  basePrice     Int          // в сумах
  discount      Int          @default(0)
  totalPrice    Int          // basePrice - discount
  promoCode     String?

  // Структура коэффициентов / расчёта — JSON для гибкости.
  // Для ОСАГО: { periodK, territoryK, experienceK, limitK }, для health/home — null.
  coefficients  Json?

  // Заполняется при ACTIVE
  policyNumber  String?      @unique
  qrPayload     String?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  activatedAt   DateTime?

  drivers       PolicyDriver[]

  @@index([userId, status])
  @@map("policies")
}

// M:N связь полиса и водителей.
model PolicyDriver {
  policyId String
  policy   Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  driverId String
  driver   Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@id([policyId, driverId])
  @@map("policy_drivers")
}

model Promo {
  id           String   @id @default(cuid())
  code         String   @unique
  discountPct  Int      // 0..100
  validFrom    DateTime?
  validUntil   DateTime?
  maxUses      Int?     // null = безлимит
  usesCount    Int      @default(0)
  isActive     Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("promos")
}

model Card {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  brand     CardBrand
  last4     String    // 4 цифры
  expiry    String    // "MM/YY"
  token     String    // mock-токен от платёжки (в реале — Uzcard tokenization)
  isDefault Boolean   @default(false)
  balance   Int       @default(5000000) // mock-баланс карты в сумах

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  payments  Payment[]

  @@unique([userId, token])
  @@index([userId])
  @@map("cards")
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  balance   Int      @default(0) // в сумах

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String       @id @default(cuid())
  walletId    String
  wallet      Wallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)

  type        WalletTxType
  amount      Int          // положительное для TOPUP/REFUND/BONUS, отрицательное для PAYMENT
  description String?
  paymentId   String?      // связь с Payment если это списание за полис

  createdAt   DateTime     @default(now())

  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

model Partner {
  id        String      @id @default(cuid())
  name      String
  type      PartnerType
  address   String
  phone     String?
  rating    Float       @default(0)
  isOpen    Boolean     @default(true)
  city      String      @default("Ташкент")
  lat       Float?
  lng       Float?

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([type])
  @@index([city])
  @@map("partners")
}

model Payment {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  policyId  String
  // Не делаем relation на Policy здесь чтобы избежать циклов в seed/удалении;
  // policyId хранится как FK-like reference.

  amount    Int
  method    PaymentMethod
  cardId    String?
  card      Card?          @relation(fields: [cardId], references: [id], onDelete: SetNull)

  status    PaymentStatus  @default(PENDING)
  error     String?        // текст ошибки если FAILED

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  paidAt    DateTime?

  @@index([userId, status])
  @@index([policyId])
  @@map("payments")
}

model AdjusterRequest {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation("RequestOwner", fields: [userId], references: [id], onDelete: Cascade)

  policyId     String?        // связанный полис (необязательно)
  incidentType IncidentType
  address      String
  lat          Float?
  lng          Float?
  comment      String?
  adjusterNote String?        @map("adjuster_note")
  status       AdjusterStatus @default(NEW)

  // Назначенный аджастер — системный пользователь с ролью ADJUSTER
  assignedAdjusterId String?  @map("assigned_adjuster_id")
  assignedAdjuster   User?    @relation("AssignedAdjuster", fields: [assignedAdjusterId], references: [id], onDelete: SetNull)

  // Одноразовый аджастер (без аккаунта в системе)
  adjusterName  String?  @map("adjuster_name")
  adjusterPhone String?  @map("adjuster_phone")

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId])
  @@index([status, createdAt])
  @@index([assignedAdjusterId])
  @@map("adjuster_requests")
}

// Второй участник европротокола — личность, подтверждённая через MyID.
// Find-or-create по ПИНФЛ. Не логинимый аккаунт (отдельно от User).
// Авто и полис участника привязаны к конкретному ДТП, а не к личности,
// поэтому здесь хранится только MyID-профиль.
model EuroParticipant {
  id         String    @id @default(cuid())
  pinfl      String    @unique

  // MyID-профиль
  name       String?
  surname    String?
  patronymic String?
  nameEn     String?   @map("name_en")
  surnameEn  String?   @map("surname_en")
  birthDate  DateTime? @map("birth_date")
  birthPlace String?   @map("birth_place")
  gender     String?
  nationality String?
  citizenship String?
  address    String?

  // Паспорт
  passportSeria  String? @map("passport_seria")
  passportNumber String? @map("passport_number")

  myidRaw    Json?     @map("myid_raw")
  verifiedAt DateTime  @default(now()) @map("verified_at")

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  protocols  EuroProtocol[]

  @@map("euro_participants")
}

// Статус европротокола (флоу урегулирования/выплаты).
enum EuroStatus {
  SUBMITTED  // подано
  REVIEW     // на рассмотрении
  NEED_INFO  // требуется информация
  APPROVED   // одобрено
  REJECTED   // отклонено
  PAID       // выплачено
}

// Оформленный европротокол — собранные данные ДТП (без PDF пока).
model EuroProtocol {
  id     String @id @default(cuid())
  number String @unique // EP-26-XXXXX

  // Сторона A — инициатор
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleId    String?
  vehicle      Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  selfVerified Boolean  @default(false)

  // Обстоятельства
  incidentDate DateTime
  incidentTime String
  place        String
  lat          Float?
  lng          Float?

  // Сторона B — второй участник
  participantId     String?          @map("participant_id")
  participant       EuroParticipant? @relation(fields: [participantId], references: [id], onDelete: SetNull)
  otherGov          String?          @map("other_gov")
  otherPhone        String?          @map("other_phone")
  otherVehicleRaw   Json?            @map("other_vehicle_raw") // TechPassportInfo из НАПП
  otherPolicySeria  String?          @map("other_policy_seria")
  otherPolicyNumber String?          @map("other_policy_number")
  otherPolicyValid  Boolean?         @map("other_policy_valid")

  // Схема / описание / фото
  schemeType     String? @map("scheme_type")
  schemeImageKey String? @map("scheme_image_key") // ключ нарисованной/загруженной схемы в MinIO
  description    String? // = оборот «1. ЙТҲ ҳолати» (обстоятельства своими словами)
  photos         Json?   // массив ключей MinIO + метаданные

  // --- Общая часть бланка (пп. 4–6) ---
  medCheck           Boolean? @map("med_check")            // 4. медосвидетельствование пройдено
  witnesses          String?                               // 5. свидетели (ФИО, адрес)
  officialRegistered Boolean? @map("official_registered")  // 6. оформлено сотрудником ИИО/ДЙҲХ
  officerBadgeNo     String?  @map("officer_badge_no")      // 6. № нагрудного знака

  // --- Обстоятельства ДТП: 22 чекбокса на каждую сторону (массив boolean[22]) ---
  circumstancesA Json? @map("circumstances_a")
  circumstancesB Json? @map("circumstances_b")

  // --- Сторона A: доп. поля бланка ---
  ownershipDocA String? @map("ownership_doc_a") // документ о праве владения (если водитель ≠ владелец)
  damageDescA   String? @map("damage_desc_a")   // 12. описание повреждений
  objectionsA   String? @map("objections_a")    // 13. возражения
  impactZoneA   String? @map("impact_zone_a")    // 11. зона первого удара (код зоны)

  // --- Сторона B: ручной ввод (НАПП/MyID не покрывают) ---
  otherOwnerAddr        String?   @map("other_owner_addr")
  otherDlSeria          String?   @map("other_dl_seria")
  otherDlNumber         String?   @map("other_dl_number")
  otherDlCategories     String?   @map("other_dl_categories")
  otherDlIssue          DateTime? @map("other_dl_issue") @db.Date
  otherOwnershipDoc     String?   @map("other_ownership_doc")
  otherInsurer          String?   @map("other_insurer")
  otherPolicyValidUntil DateTime? @map("other_policy_valid_until") @db.Date
  damageDescB           String?   @map("damage_desc_b")
  objectionsB           String?   @map("objections_b")
  impactZoneB           String?   @map("impact_zone_b")

  // --- Оборот (стр. 2) ---
  driverRole      String?  @map("driver_role")       // 'owner' | 'other'
  canMove         Boolean? @map("can_move")          // ТС может двигаться самостоятельно
  cannotMovePlace String?  @map("cannot_move_place") // место стоянки, если не может
  remarks         String?                            // 4. Изоҳ (доп. замечания)

  // --- Подписи (OTP/MyID — храним факт + время, рендерим штамп) ---
  signedAAt DateTime? @map("signed_a_at") // сторона A (инициатор, MyID step-up)
  signedBAt DateTime? @map("signed_b_at") // сторона B (OTP по otherPhone)

  status    EuroStatus @default(SUBMITTED)
  adminNote String?    @map("admin_note")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status, createdAt])
  @@map("euro_protocols")
}
